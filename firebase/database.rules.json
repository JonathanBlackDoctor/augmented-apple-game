{
  "rules": {
    "profiles": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['nickname','mmr','tier'])"
      }
    },
    "leaderboard": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },
    "queue": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('players').child(auth.uid).exists() || !data.child('meta/guestUid').exists())",
        "match": {
          "events": {
            "$pushId": {
              ".validate": "newData.child('player').val() === auth.uid || newData.child('from').val() === auth.uid"
            }
          }
        }
      }
    },
    "daily": {
      "$d": {
        ".read": true,
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    }
  }
}
